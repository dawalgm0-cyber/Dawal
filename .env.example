# DAWAL environment (Section 9). Copy to .env and fill in.
# For docker-compose, DATABASE_URL is overridden to point at the postgres service.
DATABASE_URL=postgresql+psycopg://dawal:dawal@localhost:5432/dawal
# JWT_SECRET must be >= 32 bytes in production (HS256). Generate e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production-use-a-32plus-byte-random-secret
# SMS: mock (no network) or africastalking_sandbox (real AT sandbox API).
SMS_PROVIDER=mock
SMS_OTP_USERNAME=sandbox
SMS_OTP_API_KEY=            # Africa's Talking API key (sandbox or live)
ADMIN_DEFAULT_EMAIL=admin@dawal.app
ADMIN_DEFAULT_PASSWORD=changeme123
APP_BASE_URL=http://localhost:8000
TIMEZONE=Africa/Banjul
CURRENCY=GMD
