# DAWAL production environment template. Copy to your host's env / secrets.
# NEVER commit the filled-in version.

# --- database (managed Postgres 16 on your host) ---
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/dawal

# --- security ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME_32_PLUS_BYTES

# --- admin bootstrap (seeded on first start; change immediately after) ---
ADMIN_DEFAULT_EMAIL=you@yourdomain.com
ADMIN_DEFAULT_PASSWORD=CHANGE_ME_STRONG

# --- public URLs (real domains) ---
APP_BASE_URL=https://api.yourdomain.com
RIDER_APP_URL=https://dawal.netlify.app
# Comma-separated origins allowed to call the API (rider + driver + admin sites).
CORS_ORIGINS=https://dawal.netlify.app,https://driver.yourdomain.com,https://admin.yourdomain.com

# --- SMS (Africa's Talking) ---
# Sandbox for staging; switch to your live username + key for production sends.
SMS_PROVIDER=africastalking_sandbox
SMS_OTP_USERNAME=sandbox
SMS_OTP_API_KEY=YOUR_AT_API_KEY

# --- locale ---
TIMEZONE=Africa/Banjul
CURRENCY=GMD

# --- scheduler (leave enabled on exactly ONE backend instance) ---
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_HOURS=24
